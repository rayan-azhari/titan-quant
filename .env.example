# titan-quant demo environment (copy to .env and edit).
# PAPER ONLY. Never put live-account credentials in this file.

# --- IBKR paper gateway (only needed for the live/paper demo) -------------
# Use your IBKR *paper* credentials. The demo defaults to paper port 4002.
TWS_USERID=your_paper_username
TWS_PASSWORD=your_paper_password
TRADING_MODE=paper            # paper | live  (keep "paper")
IBKR_HOST=127.0.0.1
IBKR_PORT=4002                # paper=4002, live=4001 (do not change unless you mean it)
IBKR_CLIENT_ID=1
# Your IBKR paper account id (format DUxxxxxxx). Required only for the live demo.
IBKR_ACCOUNT_ID=DUxxxxxxx

# --- Optional notifications (leave blank to disable) ----------------------
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
